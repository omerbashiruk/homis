# ---------------------------------------------------------------------------
# Ramadan Close — environment template. Copy to `.env` and fill in.
# NEVER commit the real .env. Card data never touches us (Zettle + Stripe do PCI).
# ---------------------------------------------------------------------------

# Which backend the contract (src/core/api-client.ts) talks to.
#   mock = in-memory fixtures (Step 0 default — Dev B builds the UI against this)
#   http = real Fastify API at API_BASE_URL (swap in once §7 endpoints are live)
RAMADAN_CLOSE_BACKEND=mock
API_BASE_URL=http://localhost:8080

# HTTP server
PORT=8080
HOST=0.0.0.0

# Database (Postgres). Money is stored as integer pence.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ramadan_close?schema=public

# Stripe (billing: one-time activation fee + annual subscription)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_ACTIVATION_PRICE_ID=price_xxx
STRIPE_SUBSCRIPTION_PRICE_ID=price_xxx

# Zettle (donation card-present payments — runs in the operator's device layer)
ZETTLE_CLIENT_ID=xxx
ZETTLE_CLIENT_SECRET=xxx
ZETTLE_ENVIRONMENT=sandbox

# Receipts (async, non-blocking)
TWILIO_ACCOUNT_SID=xxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+44xxxxxxxxxx
SENDGRID_API_KEY=xxx
RECEIPTS_FROM_EMAIL=donations@example.org
